{
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "crons": [{
    "path": "/api/add_snapshot",
    "schedule": "30 12 * * *"
  }],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}